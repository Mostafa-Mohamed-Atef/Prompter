{
  "manifest_version": 3,
  "name": "Prompter",
  "version": "1.0.0",
  "description": "Store and auto-input prompts into AI chat models.",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "favicon_io/icon16.png",
      "32": "favicon_io/icon32.png"
    }
  },
  "icons": {
    "16": "favicon_io/icon16.png",
    "32": "favicon_io/icon32.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle the Prompter sidebar"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.js", "styles.css"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ]
} 